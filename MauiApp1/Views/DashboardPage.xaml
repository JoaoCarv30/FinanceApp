<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
		 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
		 x:Class="MauiApp1.Views.DashboardPage"
		 Title="DashboardPage"
		 xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
		 xmlns:vms="clr-namespace:MauiApp1.ViewModels"
		 Shell.NavBarIsVisible="False"
		 Shell.BackgroundColor="{StaticResource Background}"
		 Shell.TitleColor="White"
		 Shell.ForegroundColor="White">
	<VerticalStackLayout BackgroundColor="{StaticResource Background}"
				   Padding="20"
				   Spacing="20">
		<Label Text="Welcome to .NET MAUI!"
			 FontSize="24"
			 FontAttributes="Bold"
			 TextColor="{StaticResource Primary}"
			 HorizontalOptions="Center" />
		<Label Text="Resumo por categoria" TextColor="White" FontSize="18" FontAttributes="Bold" />
		<Grid ColumnDefinitions="Auto,*"
			ColumnSpacing="16">
			<!-- Gráfico -->
			<lvc:PieChart Grid.Column="0"
					  SeriesSource="{Binding Data}"
					  HeightRequest="200"
					  WidthRequest="200"
					  Background="Transparent"
					  HorizontalOptions="Start"
					  VerticalOptions="Center">
				<lvc:PieChart.SeriesTemplate>
					<DataTemplate x:DataType="vms:PieData">
						<lvc:XamlPieSeries SeriesName="{Binding Name}"
									 Values="{Binding Values}"
									 MaxRadialColumnWidth="40">
							<lvc:XamlPieSeries.Fill>
								<Binding Path="Paint" />
							</lvc:XamlPieSeries.Fill>
						</lvc:XamlPieSeries>
					</DataTemplate>
				</lvc:PieChart.SeriesTemplate>
			</lvc:PieChart>
			<!-- Legenda -->
			<VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
				<Grid 
					VerticalOptions="Center"
					HorizontalOptions="Start">
					<Grid ColumnDefinitions="Auto, Auto">
						<HorizontalStackLayout Spacing="8"
									     VerticalOptions="Center">
							<Border WidthRequest="14"
								  HeightRequest="14"
								  BackgroundColor="{StaticResource Primary}"
								  StrokeThickness="0">
								<Border.StrokeShape>
									<RoundRectangle CornerRadius="4" />
								</Border.StrokeShape>
							</Border>
							<Label Text="Alimentação"
								 FontSize="14"
								 TextColor="White"
								 LineBreakMode="NoWrap" />
						</HorizontalStackLayout>
						<Label 	       Grid.Column="1"
									 Text="30%"
									 TextColor="White"
									 FontSize="14"
									 Margin="22,0,0,0" />
					</Grid>
				</Grid>
				<Grid VerticalOptions="Center"
					HorizontalOptions="Start">
					<Grid ColumnDefinitions="Auto, Auto">
						<HorizontalStackLayout Spacing="8"
									     VerticalOptions="Center">
							<Border WidthRequest="14"
								  HeightRequest="14"
								  BackgroundColor="{StaticResource Primary}"
								  StrokeThickness="0">
								<Border.StrokeShape>
									<RoundRectangle CornerRadius="4" />
								</Border.StrokeShape>
							</Border>
							<Label Text="Alimentação"
								 FontSize="14"
								 TextColor="White"
								 LineBreakMode="NoWrap" />
						</HorizontalStackLayout>
						<Label 	       Grid.Column="1"
									 Text="30%"
									 TextColor="White"
									 FontSize="14"
									 Margin="22,0,0,0" />
					</Grid>
				</Grid>
				<Grid VerticalOptions="Center"
					HorizontalOptions="Start">
					<Grid ColumnDefinitions="Auto, Auto">
						<HorizontalStackLayout Spacing="8"
									     VerticalOptions="Center">
							<Border WidthRequest="14"
								  HeightRequest="14"
								  BackgroundColor="{StaticResource Primary}"
								  StrokeThickness="0">
								<Border.StrokeShape>
									<RoundRectangle CornerRadius="4" />
								</Border.StrokeShape>
							</Border>
							<Label Text="Alimentação"
								 FontSize="14"
								 TextColor="White"
								 LineBreakMode="NoWrap" />
						</HorizontalStackLayout>
						<Label 	       Grid.Column="1"
									 Text="30%"
									 TextColor="White"
									 FontSize="14"
									 Margin="22,0,0,0" />
					</Grid>
				</Grid>
			</VerticalStackLayout>
		</Grid>
	</VerticalStackLayout>
</ContentPage>