<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Extenders.Components.Transaction">
	<Grid ColumnDefinitions="Auto, *, Auto">
		<Grid>
			<HorizontalStackLayout>
				<Image Source="category_health_icon.png" WidthRequest="32" HeightRequest="32" />
				<VerticalStackLayout Spacing="4"
							   Margin="12,0,0,0">
					<Label Text="Saúde"
						 TextColor="White"
						 FontSize="16"
						 FontFamily="InterBold" />
					<Label Text="Farmácia"
						 TextColor="White"
						 FontSize="14"
						 FontFamily="InterRegular" />
				</VerticalStackLayout>
			</HorizontalStackLayout>
		</Grid>
		<Grid Grid.Column="2">
			<VerticalStackLayout>
				<Label Text="+ R$ 5.400,00"
					 TextColor="{StaticResource Primary}"
					 FontSize="16"
					 FontFamily="InterBold" />
				<Label Text="Hoje"
					 HorizontalOptions="End"
					 TextColor="White"
					 FontSize="14"
					 FontFamily="InterRegular" />
			</VerticalStackLayout>
		</Grid>
	</Grid>
</ContentView>
