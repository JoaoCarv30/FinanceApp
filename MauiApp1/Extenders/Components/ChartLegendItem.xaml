<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MauiApp1.Extenders.Components.ChartLegendItem"
		 xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
		 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
		 x:Name="Root">
	<Grid VerticalOptions="Center"
		HorizontalOptions="Start">
		<Grid ColumnDefinitions="Auto,Auto">
			<HorizontalStackLayout Spacing="8"
						     VerticalOptions="Center">
				<Border WidthRequest="14"
					  HeightRequest="14"
					  BackgroundColor="{Binding Color, Source={x:Reference Root}}"
					  StrokeThickness="0">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="4" />
					</Border.StrokeShape>
				</Border>
				<Label Text="{Binding Title, Source={x:Reference Root}}"
					 FontSize="14"
					 TextColor="White"
					 LineBreakMode="NoWrap" />
			</HorizontalStackLayout>
			<Label Grid.Column="1"
				 Text="{Binding Percent, Source={x:Reference Root}}"
				 TextColor="White"
				 FontSize="14"
				 Margin="22,0,0,0" />
		</Grid>
	</Grid>
</ContentView>