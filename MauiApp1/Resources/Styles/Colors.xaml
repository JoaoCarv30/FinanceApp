<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- App Finance Theme -->

    <!-- Base -->
    <Color x:Key="Primary">#22C55E</Color>
    <Color x:Key="PrimaryDark">#16A34A</Color>
    <Color x:Key="PrimaryDarkText">#E5E7EB</Color>

    <Color x:Key="Secondary">#121821</Color>
    <Color x:Key="SecondaryDarkText">#9CA3AF</Color>

    <Color x:Key="Tertiary">#4ADE80</Color>

    <!-- Backgrounds -->
    <Color x:Key="Background">#101318</Color>
    <Color x:Key="Surface">#121821</Color>
    <Color x:Key="SurfaceDark">#0F172A</Color>
    <Color x:Key="Border">#1E2633</Color>
    <Color x:Key="Divider">#1F2937</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#E5E7EB</Color>
    <Color x:Key="TextSecondary">#9CA3AF</Color>
    <Color x:Key="TextMuted">#6B7280</Color>

    <!-- Status -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessDark">#16A34A</Color>
    <Color x:Key="SuccessLight">#4ADE80</Color>

    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerDark">#DC2626</Color>
    <Color x:Key="DangerLight">#F87171</Color>

    <!-- Categories -->
    <Color x:Key="CategoryBlue">#3B82F6</Color>
    <Color x:Key="CategoryOrange">#F59E0B</Color>
    <Color x:Key="CategoryPurple">#8B5CF6</Color>
    <Color x:Key="CategoryGreen">#10B981</Color>
    <Color x:Key="CategoryGray">#6B7280</Color>

    <!-- Default -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#0B0F14</Color>

    <!-- Grays -->
    <Color x:Key="Gray100">#E5E7EB</Color>
    <Color x:Key="Gray200">#D1D5DB</Color>
    <Color x:Key="Gray300">#9CA3AF</Color>
    <Color x:Key="Gray400">#6B7280</Color>
    <Color x:Key="Gray500">#4B5563</Color>
    <Color x:Key="Gray600">#374151</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#0B0F14</Color>

    <Color x:Key="MidnightBlue">#0B0F14</Color>
    <Color x:Key="Magenta">#22C55E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDark}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLight}" />

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="DangerDarkBrush" Color="{StaticResource DangerDark}" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLight}" />

    <SolidColorBrush x:Key="CategoryBlueBrush" Color="{StaticResource CategoryBlue}" />
    <SolidColorBrush x:Key="CategoryOrangeBrush" Color="{StaticResource CategoryOrange}" />
    <SolidColorBrush x:Key="CategoryPurpleBrush" Color="{StaticResource CategoryPurple}" />
    <SolidColorBrush x:Key="CategoryGreenBrush" Color="{StaticResource CategoryGreen}" />
    <SolidColorBrush x:Key="CategoryGrayBrush" Color="{StaticResource CategoryGray}" />

    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />

</ResourceDictionary>